{
  "workbench.colorTheme": "Quiet Light",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "files.readonlyFromPermissions": true,
  "explorer.confirmDragAndDrop": false,
  "go.toolsManagement.autoUpdate": true,
  "go.alternateTools": {
    "go": "/opt/homebrew/bin/go",
  },
  "git.openRepositoryInParentFolders": "always",
  "[rust]": {
    "editor.formatOnSave": false,
  },
  "[javascript][json][typescript][typescriptreact][json5][jsonc]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "hexeditor.dataInspector.autoReveal": false,
  "hexeditor.showOpenFileButton": true,
  "hexeditor.inspectorType": "sidebar",
  "files.insertFinalNewline": true,
  "editor.unicodeHighlight.nonBasicASCII": true,
  "extensions.ignoreRecommendations": true,
  "editor.renderWhitespace": "all",
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "toml": false,
  },
  "files.associations": {
    "*.sage": "python",
  },
  "python.analysis.extraPaths": ["~/local_python/lib/python3.12/site-packages"],
  "git.ignoreMissingGitWarning": true,
  "solidity.telemetry": false,
  "makefile.configureOnOpen": false,
  "git.enabled": true,
  "git.autorefresh": false,
  "git.autofetch": false,
  "git.decorations.enabled": false,
  // https://qiita.com/nolanlover0527/items/071277263f8851012e6b
  // ファイル監視の除外
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.vscode/**": true,
    "**/coverage/**": true,
    "**/__generated__/**": true,
  },
  // エクスプローラーから除外
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
  },
  // 検索から除外
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
  },
  "files.autoGuessEncoding": true,
  "lean4.alwaysAskBeforeInstallingLeanVersions": false,
  "js/ts.experimental.useTsgo": true,
  "python.analysis.typeCheckingMode": "strict",
  "terminal.integrated.suggest.enabled": false,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.stickyScroll.enabled": false,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "editor.codeLens": false,
  "workbench.activityBar.location": "hidden",
}
